# Make sure to enable 1Password SSH Agent 
# and generate the bookmarks config from the settings
# in SSH Agent settings (developer tab)
Include ~/.ssh/1Password/config

# personal gitlab
Host gitlab.com
	HostName gitlab.com
	User git
	IdentityFile ~/.ssh/id_personal_gitlab
# personal github
Host github.com
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_personal_github
	IdentitiesOnly yes
# work gitlab
Host gitlab.com-spotilla
	HostName gitlab.com
	User git
	IdentityFile ~/.ssh/id_work_gitlab

Host *
  SetEnv TERM=xterm-256color
  IdentityAgent ~/.1password/agent.sock
